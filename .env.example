SPRING_PROFILES_ACTIVE=운영환경에 맞게
TZ=Asia/Seoul

# APP_IMAGE 는 운영 전용 (.env.production.example 참고)
# POSTGRES_DB / POSTGRES_USER / POSTGRES_PASSWORD 는 docker-compose.local.yml 에 하드코딩되어 있으므로 여기서 설정하지 않음

DB_URL=jdbc:postgresql://localhost:5432/thejejachurch
DB_USERNAME=postgres
DB_PASSWORD=postgres

YOUTUBE_API_KEY=replace-me
YOUTUBE_MESSAGES_PLAYLIST_ID=replace-me
YOUTUBE_BETTER_DEVOTION_PLAYLIST_ID=replace-me
YOUTUBE_ITS_OKAY_PLAYLIST_ID=replace-me
ADMIN_SYNC_KEY=replace-me
ADMIN_BOOTSTRAP_USERNAME=super-admin
ADMIN_BOOTSTRAP_PASSWORD=replace-me
ADMIN_BOOTSTRAP_DISPLAY_NAME=슈퍼 관리자

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
